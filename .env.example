# Solana Indexer — environment template
# Copy to .env and edit:  cp .env.example .env

# =============================================================================
# DATA SOURCES
# =============================================================================

# HTTP JSON-RPC —> used for RPC fallback, account watcher, leaders, blocks.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com


# # Yellowstone gRPC for real-time streaming (fastest, recommended) real-time slots + transactions on `start` / `track slots`.
# Uncomment when you have a Geyser endpoint:

# YELLOWSTONE_GRPC_URL=http://localhost:10000
# YELLOWSTONE_GRPC_TOKEN=


# =============================================================================
# DATABASE (pick SQLite OR PostgreSQL)
# =============================================================================

# SQLite file path (default: indexer.db in project root). Migrations run on startup.
SQLITE_DB_PATH=indexer.db

# PostgreSQL — if set, used instead of SQLite (optional)
# DATABASE_URL=postgres://user:pass@localhost:5432/indexer


# =============================================================================
# IN-MEMORY CACHE (MultiCache L1 / L2 / L3)
# =============================================================================

# L1 hot slots | L2 transactions (1h TTL) | L3 accounts (memory + DB fallback)
CACHE_L1_SIZE=1000
CACHE_L2_SIZE=10000
CACHE_L3_SIZE=5000


# =============================================================================
# RUNTIME (`indexer start`)
# =============================================================================

# Comma-separated addresses watched in parallel with the slot pipeline (optional)
# WATCH_ACCOUNTS=So11111111111111111111111111111111111111112,EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v


# =============================================================================
# HTTP QUERY API (extension — CLI `query` works without this)
# =============================================================================

# When set, Axum server runs in parallel on `indexer start`. Also used by `indexer serve`
# when --port is omitted (serve defaults to 8080 if this is also unset).
# (optional)
# API_PORT=8080
# API_KEY=your-secret-key
# API_BIND_LOCALHOST=1

# Min ms between RPC get_block calls for Yellowstone slot enrichment (default: 2000)
# SLOT_ENRICH_MIN_INTERVAL_MS=2000


# =============================================================================
# LOGGING (tracing — read by logger.rs, not Config)
# =============================================================================

# (optional, default: info)
# RUST_LOG=info,solana_indexer=debug


# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Re-apply SQL migrations after checksum mismatch. Never use in production.
# (optional)
# ALLOW_MIGRATION_RESET=1
