# Solana Indexer — environment template
# Copy to .env and edit:  cp .env.example .env

# =============================================================================
# DATA SOURCES
# =============================================================================

# HTTP JSON-RPC — fallback, account watcher, leaders, block enrichment.
# Use a real provider (Helius, QuickNode, etc.) for enrichment and production.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional dedicated RPC for slot get_block enrichment (defaults to SOLANA_RPC_URL)
# ENRICHMENT_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Yellowstone gRPC — real-time slots on `start` / `track slots`.
# YELLOWSTONE_GRPC_URL=https://your-geyser-host:443
# YELLOWSTONE_GRPC_TOKEN=

# Optional filtered Yellowstone tx stream (empty = slots only; safer for hosted providers)
# YELLOWSTONE_TX_ACCOUNTS=So11111111111111111111111111111111111111112

# =============================================================================
# DATABASE (pick SQLite OR PostgreSQL / Supabase)
# =============================================================================

# SQLite when DATABASE_URL is unset (default: indexer.db). Migrations run on startup.
SQLITE_DB_PATH=indexer.db

# PostgreSQL — Supabase, Neon, RDS, or local Postgres. Takes priority over SQLite.
# Supabase: Settings → Database → Connection string (Session pooler recommended).
# Example:
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# =============================================================================
# IN-MEMORY CACHE (MultiCache L1 / L2 / L3)
# =============================================================================

CACHE_L1_SIZE=1000
CACHE_L2_SIZE=10000
CACHE_L3_SIZE=5000

# =============================================================================
# RUNTIME (`solana-indexer start`)
# =============================================================================

# Comma-separated addresses watched in parallel with the slot pipeline (optional)
# WATCH_ACCOUNTS=So11111111111111111111111111111111111111112

# =============================================================================
# HTTP QUERY API
# =============================================================================

# API_PORT=8080
# API_KEY=your-secret-key
# API_BIND_LOCALHOST=1

# Min ms between RPC get_block calls for Yellowstone slot enrichment (default: 2000)
# Lower (e.g. 500) for testing; requires a good SOLANA_RPC_URL
# SLOT_ENRICH_MIN_INTERVAL_MS=2000

# =============================================================================
# LOGGING
# =============================================================================

# RUST_LOG=info,solana_indexer=debug

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# ALLOW_MIGRATION_RESET=1
